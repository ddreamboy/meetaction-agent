# LLM
LLM_BASE_URL=https://routerai.ru/api/v1
LLM_API_KEY=...
LLM_MODEL=google/gemini-2.5-flash-lite
LLM_TIMEOUT=60
LLM_RETRY_COUNT=2
EMBEDDING_MODEL=google/gemini-embedding-001

# Todoist
TODOIST_API_TOKEN=...
# TODOIST_PROJECT_ID=  # опционально

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Agent
MAX_REFINEMENT_COUNT=2
SESSION_TTL_SECONDS=1800
CLASSIFIER_DEFAULT=work_meeting
TOKEN_BUDGET_WARNING=500000

# Transcription backend: "local" (whisperx, default) | "deepgram"
TRANSCRIBE_BACKEND=local

# Whisperx (используется если TRANSCRIBE_BACKEND=local)
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# Optional: needed for pyannote speaker diarization models on Hugging Face
HF_TOKEN=...

# DeepGram (используется если TRANSCRIBE_BACKEND=deepgram)
# DEEPGRAM_API_URL=https://api.deepgram.com/v1/listen
# DEEPGRAM_API_KEY=...
# DEEPGRAM_MODEL=nova-2
# DEEPGRAM_LANGUAGE=ru
# DEEPGRAM_DIARIZE=true

# Limits
MAX_AUDIO_DURATION_SECONDS=5400
